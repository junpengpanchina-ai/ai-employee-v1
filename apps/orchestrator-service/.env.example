# ========================================
# orchestrator-service
# AI 总经理 / GRSAI / Supabase 中枢
# ========================================

APP_ENV=local
LOG_LEVEL=info

# 监听地址（Railway 等容器需 0.0.0.0，默认已是）
# HOST=0.0.0.0
# 服务端口（Railway 用自动注入的 PORT 优先）
ORCHESTRATOR_PORT=8001

# 默认模型
BOT_MODEL=gemini-3.1-pro

# GRSAI
GRSAI_API_KEY=
GRSAI_BASE_URL=
GRSAI_COMPLETIONS_PATH=/chat/completions

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 浏览器跨域：Vercel 前端域名，多个用英文逗号分隔，无尾斜杠
# CORS_ORIGIN=https://你的项目.vercel.app

# --- WorldMonitor /intel（Telegram /intel 真简报）---
# 二选一：
# • WORLDMONITOR_INTEL_EXPORT_URL = 完整导出 URL（不要再含第二份 /api/export/intel）
# • WORLDMONITOR_PUBLIC_URL = 仅站点根（无 /api/export/intel）；若误填完整导出 URL，代码会去重拼接
# 公网示例：
# WORLDMONITOR_PUBLIC_URL=https://xxx.up.railway.app
# 同项目 Railway 私有网络（*.railway.internal）请用 http，不要用 https；若仍失败可带端口与 WM 一致，例如：
# WORLDMONITOR_PUBLIC_URL=http://worldmonitor.railway.internal:4173
# WORLDMONITOR_INTEL_EXPORT_URL=https://xxx.up.railway.app/api/export/intel
#
# 鉴权（按需二选一或同时，视 WM 文档）：
# • 官网 api.worldmonitor.app：控制台发的 token → WORLDMONITOR_BEARER_TOKEN（可带或不带 Bearer 前缀）
# • 自托管 Vercel WM（validateApiKey / X-WorldMonitor-Key）：填与 WORLDMONITOR_VALID_KEYS 中某一把相同的 wm_…
# WORLDMONITOR_BEARER_TOKEN=
# WORLDMONITOR_GATE_KEY=
#
# 可选：拉取超时（毫秒）、最多条数、RSS User-Agent（见 intelSources/rss.js）
# INTEL_FEED_TIMEOUT_MS=25000
# INTEL_FEED_MAX_ITEMS=80
# INTEL_FEED_USER_AGENT=ai-employee-v1-orchestrator/1.0
# 非 2xx 时日志里打印响应体前缀长度（调试用）
# INTEL_FEED_BODY_LOG_MAX=400
#
# --- 供料兜底：WM 不可用时按序尝试 RSS 源 / 内置 mock ---
# 说明：顺序为 WM → RSS → mock；其中任一层有结果立即返回，不再尝试下一层。
# 官方 www.worldmonitor.app 不对外提供 /api/export/intel，自建实例或未接时请用以下两项兜底。
#
# 逗号/空白分隔的 RSS / Atom / JSON Feed URL；单源失败不影响其它源。（示例为扩源混合）
# INTEL_FALLBACK_FEEDS=https://feeds.bbci.co.uk/news/business/rss.xml,https://feeds.bbci.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/Business.xml,https://news.ycombinator.com/rss,https://techcrunch.com/feed/,https://feeds.arstechnica.com/arstechnica/index,https://www.theverge.com/rss/index.xml,https://www.theguardian.com/world/rss,https://www.coindesk.com/arc/outboundfeeds/rss/
#
# 是否允许在所有真实源都不可用时使用内置 mock（仅用于跑通链路；上线请置 false）
# INTEL_ALLOW_MOCK=false
#
# --- intel_items 读库总结（需在 Supabase 执行 supabase/migrations/*_intel_items.sql）---
# INTEL_SINCE_HOURS=24
# 分时段默认读库窗口（小时），仅当使用 morning/noon/night 且未写死 48h 等时生效
# INTEL_SLOT_MORNING_SINCE_HOURS=16
# INTEL_SLOT_NOON_SINCE_HOURS=6
# INTEL_SLOT_NIGHT_SINCE_HOURS=14
#
# P2.5：有 slot 且消息/请求未显式带 topic 时，读库按下列过滤（也可用 topic= 覆盖）
# 未设置环境变量时的代码默认：早报 macro、午报 startup、晚报 all（不过滤）
# INTEL_SLOT_MORNING_TOPIC=macro
# INTEL_SLOT_NOON_TOPIC=startup
# INTEL_SLOT_NIGHT_TOPIC=all
# 仅当 channel 仍为 all 时生效；自定义 channel 优先
# INTEL_SLOT_MORNING_CHANNEL=all
# INTEL_SLOT_NOON_CHANNEL=all
# INTEL_SLOT_NIGHT_CHANNEL=all
# /intel 时若窗口内无行，是否先 sync 再读库（默认 true）
# INTEL_SYNC_ON_INTEL_IF_EMPTY=true
# 读库仍为空时是否再现场 GET 导出 URL（默认 true，便于未建表时兼容；表稳定后可设 false）
# INTEL_FALLBACK_LIVE_FETCH=true
#
# 保护 POST /internal/intel/sync、GET /internal/intel/brief、POST /internal/intel/push（不设则同 ingest，仅靠网络隔离）
# ORCHESTRATOR_INTERNAL_SECRET=
#
# --- 定时推 Telegram（orchestrator → bot-service /internal/notify）---
# 老板 chat id（纯数字，可向 @userinfobot 索取）；也可在 push 请求里传 chat_id
# TELEGRAM_BOSS_CHAT_ID=
# bot 服务公网根（Railway 上 bot-service 的 https URL，无尾斜杠）
# BOT_SERVICE_BASE_URL=https://your-bot.up.railway.app
# 与 bot-service 一致；不设时可与 ORCHESTRATOR_INTERNAL_SECRET 同值
# BOT_INTERNAL_SECRET=
#
# 读库时最低重要度（0=不过滤；可设 70 对齐「高质量」窗口）
# INTEL_MIN_IMPORTANCE=0
# 每次生成简报是否写入 intel_briefs（默认 true；设 false 可关）
# INTEL_PERSIST_BRIEFS=true
