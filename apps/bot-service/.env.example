# ========================================
# bot-service
# Telegram Webhook 入口与 sendMessage 回传
# ========================================

APP_ENV=local
LOG_LEVEL=info

# 服务端口
BOT_SERVICE_PORT=8010

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# 是否真实回发 Telegram
# true / false
TELEGRAM_SEND_REPLY=true

# Orchestrator
ORCHESTRATOR_BASE_URL=http://localhost:8001
