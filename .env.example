# ========================================
# ai-employee-v1 root env
# 仅作环境变量总览示例
# ========================================

APP_ENV=local
LOG_LEVEL=info

# ----------------
# bot-service
# ----------------
BOT_SERVICE_PORT=8010
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_SEND_REPLY=true
ORCHESTRATOR_BASE_URL=http://localhost:8001

# ----------------
# orchestrator-service
# ----------------
ORCHESTRATOR_PORT=8001
BOT_MODEL=gemini-3.1-pro
GRSAI_API_KEY=
GRSAI_BASE_URL=
GRSAI_COMPLETIONS_PATH=/chat/completions
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------
# admin-web
# ----------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_BASE_URL=
